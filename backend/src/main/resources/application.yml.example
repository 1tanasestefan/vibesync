server:
  port: 8080
  servlet:
    session:
      cookie:
        same-site: lax
        secure: false

# ─────────────────────────────────────────────
# PostgreSQL (matches docker-compose.yml)
# ─────────────────────────────────────────────
spring:
  datasource:
    url: jdbc:postgresql://<your-db-host>/neondb?sslmode=require&channel_binding=require
    username: <your-db-username>
    password: <your-db-password>
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: false
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect

  # ─────────────────────────────────────────────
  # Spotify OAuth2 (Authorization Code Flow)
  # ─────────────────────────────────────────────
  security:
    oauth2:
      client:
        registration:
          spotify:
            client-id: ${SPOTIFY_CLIENT_ID:your_spotify_client_id_here}
            client-secret: ${SPOTIFY_CLIENT_SECRET:your_spotify_client_secret_here}
            authorization-grant-type: authorization_code
            client-authentication-method: client_secret_basic
            redirect-uri: "{baseUrl}/login/oauth2/code/{registrationId}"
            scope: 
              - playlist-modify-public
              - playlist-modify-private
              - user-read-private
            client-name: Spotify
        provider:
          spotify:
            authorization-uri: https://accounts.spotify.com/authorize?show_dialog=true
            token-uri: https://accounts.spotify.com/api/token
            user-info-uri: https://api.spotify.com/v1/me
            user-name-attribute: id

# ─────────────────────────────────────────────
# Custom VibeSync Properties
# ─────────────────────────────────────────────
vibesync:
  ai-service:
    base-url: http://localhost:8000
    analyze-endpoint: /api/v1/analyze-vibe
  frontend:
    base-url: http://127.0.0.1:3000
  spotify:
    api-base-url: https://api.spotify.com/v1
